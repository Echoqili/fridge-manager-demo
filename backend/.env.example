# 数据库配置
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite+aiosqlite:///./data/fridge.db

# JWT 配置
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# 智谱 AI 配置
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4v

# 应用配置
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
